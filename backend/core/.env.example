# CONFIGURACION GENERAL
DEBUG=1
SECRET_KEY=dev-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS / CSRF
CORS_ALLOW_ALL=1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# JWT
JWT_ACCESS_MINUTES=480
JWT_REFRESH_DAYS=7

# TIEMPO REAL (BASE LISTA, SIN WEBSOCKETS AUN)
INVENTORY_REALTIME_ENABLED=0
INVENTORY_REALTIME_BACKEND=noop

# BASE DE DATOS
# Opciones: sqlite | postgres
DB_ENGINE=sqlite
SQLITE_NAME=db.sqlite3

# Solo si usas PostgreSQL
DB_NAME=modulo_ventas
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# SUPERUSUARIO (DEV)
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin12345
